# Natofit — Variáveis de Ambiente

# ─── SUPABASE (banco de dados) ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://qmrhtrfreezrngwismvw.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# ─── CLOUDFLARE WORKERS (backend IA) ───────────────────────────────────────────
# Após deployar os Workers, substitua pelas URLs reais:
# Formato: https://natofit-analyze-food.<seu-subdominio>.workers.dev
VITE_WORKER_ANALYZE_FOOD=https://natofit-analyze-food.SEU_SUBDOMINIO.workers.dev
VITE_WORKER_ANALYZE_BIOIMP=https://natofit-analyze-bioimp.SEU_SUBDOMINIO.workers.dev

# ─── DESENVOLVIMENTO LOCAL ──────────────────────────────────────────────────────
# Para rodar os Workers localmente:
# Terminal 1: cd workers/analyze-food && npx wrangler dev
# Terminal 2: cd workers/analyze-bioimp && npx wrangler dev
# Os Workers rodam em http://localhost:8787 e http://localhost:8788
